{
  "name": "myApp",
  "version": "1.0.0",
  "private": true,
  "description": "inisvp",
  "templateInfo": {
    "name": "ascf",
    "typescript": true,
    "css": "Sass",
    "framework": "React"
  },
  "scripts": {
    "prepare": "husky",
    "new": "taro new",
    "build:weapp": "taro build --type weapp",
    "build:swan": "taro build --type swan",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "build:rn": "taro build --type rn",
    "build:qq": "taro build --type qq",
    "build:jd": "taro build --type jd",
    "build:ascf": "taro build --type ascf",
    "build:harmony-hybrid": "taro build --type harmony-hybrid",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:swan": "npm run build:swan -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:rn": "npm run build:rn -- --watch",
    "dev:qq": "npm run build:qq -- --watch",
    "dev:jd": "npm run build:jd -- --watch",
    "dev:ascf": "npm run build:ascf -- --watch",
    "dev:harmony-hybrid": "npm run build:harmony-hybrid -- --watch",
    "watch:ascf": "cd ./ascf-project && ascf compile . --serve --logging debug",
    "run:ascf": "cd ./ascf-project && ascf build assembleAndInstallHap -r . --logging debug",
    "debug:ascf": "cd ./ascf-project && ascf compile . -c -m --logging debug",
    "release:ascf": "cd ./ascf-project && ascf compile . -c"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "author": "",
  "dependencies": {
    "@babel/runtime": "^7.24.4",
